---
import { nav, site } from "../data/site.js";

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(base, "").replace(/^\/+|\/+$/g, "");
---

<header class="site-nav">
  <div class="wrap nav-inner">
    <a class="brand" href={base}>
      <img src={`${base}logo.png`} alt="" width="36" height="36" />
      {site.shortName}
    </a>
    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav>
      <ul>
        {
          nav.map((item) => {
            const href = `${base}${item.path}`;
            const isActive = currentPath === item.path.replace(/\/$/, "");
            return (
              <li>
                <a href={href} aria-current={isActive ? "page" : undefined}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--paper);
    z-index: 10;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--ink);
    text-decoration: none;
  }

  .brand img {
    border-radius: 6px;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.75rem;
    margin: 0;
    padding: 0;
  }

  nav a {
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    padding-block: 0.25rem;
    border-bottom: 2px solid transparent;
  }

  nav a:hover,
  nav a[aria-current="page"] {
    color: var(--ink);
    border-bottom-color: var(--badger-red);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }

  .nav-toggle span {
    width: 22px;
    height: 2px;
    background: var(--ink);
    display: block;
  }

  @media (max-width: 720px) {
    .nav-toggle {
      display: flex;
    }

    nav {
      display: none;
      width: 100%;
    }

    nav.open {
      display: block;
    }

    .nav-inner {
      flex-wrap: wrap;
    }

    nav ul {
      flex-direction: column;
      gap: 0.25rem;
      padding-block: 1rem;
      width: 100%;
    }
  }
</style>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const menu = document.querySelector(".site-nav nav");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
  });
</script>
