---
import Layout from "../layouts/Layout.astro";
import { upcomingEvents, pastEvents } from "../data/events.js";

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  weekday: "short",
  month: "short",
  day: "numeric",
  year: "numeric",
});

function formatDate(isoDate) {
  return dateFormatter.format(new Date(`${isoDate}T00:00:00`));
}
---

<Layout title="Events" description="Upcoming meetings, workshops, and socials from the UW–Madison Statistics Club.">
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Events</p>
      <h1>Upcoming Events</h1>
      <div class="event-list">
        {
          upcomingEvents.map((event) => (
            <div class="card event-card">
              <div class="event-date">
                <span class="date-main">{formatDate(event.date)}</span>
                <span class="date-time">{event.time}</span>
              </div>
              <div class="event-body">
                <h3>{event.title}</h3>
                <p class="event-location">{event.location}</p>
                <p>{event.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="wrap">
      <h2>Past Events</h2>
      <ul class="past-list">
        {
          pastEvents.map((event) => (
            <li>
              <span class="past-date">{formatDate(event.date)}</span>
              <span class="past-title">{event.title}</span>
              <span class="past-desc">{event.description}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>

<style>
  .event-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .event-card {
    display: flex;
    gap: 1.5rem;
  }

  .event-date {
    flex: 0 0 8rem;
    display: flex;
    flex-direction: column;
    color: var(--badger-red);
    font-weight: 700;
  }

  .date-time {
    color: var(--ink-soft);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .event-location {
    color: var(--ink-soft);
    font-weight: 600;
    margin-top: -0.5rem;
  }

  .past-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .past-list li {
    display: grid;
    grid-template-columns: 8rem 1fr 2fr;
    gap: 1rem;
    padding-block: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .past-date {
    color: var(--ink-soft);
    font-weight: 600;
  }

  .past-title {
    font-weight: 600;
  }

  .past-desc {
    color: var(--ink-soft);
  }

  @media (max-width: 640px) {
    .event-card {
      flex-direction: column;
    }

    .event-date {
      flex-direction: row;
      gap: 0.5rem;
    }

    .past-list li {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
