---
import Layout from "../layouts/Layout.astro";
import { officers } from "../data/officers.js";

const base = import.meta.env.BASE_URL;
---

<Layout title="About" description="Our mission and the officer team behind the UW–Madison Statistics Club.">
  <section class="section">
    <div class="wrap narrow">
      <p class="eyebrow">About Us</p>
      <h1>Our Mission</h1>
      <p>
        The Undergraduate Statistics Club aims to spread statistical thinking among
        undergraduate students at UW–Madison, enhance members' statistical skills through
        events, and guide students to campus resources related to careers in statistics.
      </p>
    </div>
  </section>

  <section class="section section-soft">
    <div class="wrap">
      <h2>Officers</h2>
      <div class="grid-officers">
        {
          officers.map((officer) => (
            <div class="card officer-card">
              <img class="officer-photo" src={`${base}${officer.photo}`} alt={officer.name} />
              <h3>{officer.name}</h3>
              <p class="role">{officer.role}</p>
              <p>{officer.bio}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .narrow {
    max-width: 42rem;
  }

  .grid-officers {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .officer-card .role {
    color: var(--badger-red);
    font-weight: 600;
    margin-top: -0.5rem;
  }

  .officer-photo {
    width: 6rem;
    height: 6rem;
    object-fit: cover;
    border-radius: 50%;
    margin-bottom: 1rem;
  }

  @media (max-width: 640px) {
    .grid-officers {
      grid-template-columns: 1fr;
    }
  }
</style>
